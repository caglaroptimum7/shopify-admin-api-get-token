{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "rootDir": "server",
    "outDir": "dist/server",
    "ignoreDeprecations": "6.0"
  },
  "include": ["server/**/*"]
}
